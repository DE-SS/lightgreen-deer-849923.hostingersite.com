NODE_ENV=production
APP_NAME=hostinger-express-test
ABLY_API_KEY=your-ably-api-key-here
CHAT_ENGINE_API_KEY=replace-with-a-strong-shared-secret
CHAT_DEFAULT_CHANNEL=global-chat
ENABLE_PUBLIC_CHAT_DEMO=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tenant_database_name
DB_USERNAME=tenant_db_user
DB_PASSWORD=tenant_db_password
CHAT_MESSAGES_TABLE=chat_messages
CHAT_AUTO_CREATE_TABLE=true
