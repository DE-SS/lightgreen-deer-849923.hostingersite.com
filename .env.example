NODE_ENV=production
APP_NAME=hostinger-express-test

# Required for Laravel -> Node signed service tokens
CHAT_ENGINE_JWT_SECRET=replace-with-strong-shared-secret
CHAT_ENGINE_JWT_ALG=HS256

# Optional legacy mode (not recommended)
ALLOW_LEGACY_API_KEY=false
CHAT_ENGINE_API_KEY=replace-if-legacy-mode-enabled

# Optional public demo mode
ENABLE_PUBLIC_CHAT_DEMO=false
ABLY_API_KEY=demo-ably-key-only-if-demo-enabled
CHAT_DEFAULT_CHANNEL=global-chat
